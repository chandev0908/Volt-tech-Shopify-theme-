{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'volt-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
<script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign products_per_page = section.settings.products_per_page

  assign thirty_days_ago = 'now' | date: '%s' | minus: 2592000
-%}

{%- paginate collection.products by products_per_page -%}

<div class="volt-collection">
  <div class="volt-container">

    {%- comment -%} Active filters — desktop {%- endcomment -%}
    <div class="active-facets-desktop volt-active-filters">
      {%- for filter in collection.filters -%}
        {%- for value in filter.active_values -%}
          <a href="{{ value.url_to_remove }}" class="js-facet-remove" aria-label="Remove filter: {{ value.label | escape }}">
            {{- value.label | escape -}}
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1 1l8 8M9 1L1 9"/>
            </svg>
          </a>
        {%- endfor -%}
        {%- if filter.type == 'price_range' -%}
          {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
            <a href="{{ filter.url_to_remove }}" class="js-facet-remove">
              {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%}
              &nbsp;–&nbsp;
              {%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M1 1l8 8M9 1L1 9"/>
              </svg>
            </a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if collection.filters.size > 0 -%}
        {%- assign active_filter_count = 0 -%}
        {%- for filter in collection.filters -%}
          {%- assign active_filter_count = active_filter_count | plus: filter.active_values.size -%}
        {%- endfor -%}
        {%- if active_filter_count > 0 -%}
          <a href="{{ collection.url }}?sort_by={{ sort_by }}" class="volt-active-filters__clear-all js-facet-remove">
            Clear all
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>

    <div class="volt-collection__layout">

      {%- comment -%} ── Desktop sidebar ── {%- endcomment -%}
      {%- if collection.filters.size > 0 -%}
        <aside class="volt-collection__sidebar" id="main-collection-filters" aria-labelledby="sidebar-filters-title">

          <div class="volt-sidebar__header">
            <p class="volt-sidebar__title" id="sidebar-filters-title">Filters</p>
            {%- assign active_count = 0 -%}
            {%- for filter in collection.filters -%}
              {%- assign active_count = active_count | plus: filter.active_values.size -%}
            {%- endfor -%}
            {%- if active_count > 0 -%}
              <a href="{{ collection.url }}?sort_by={{ sort_by }}" class="volt-sidebar__clear">Clear ({{ active_count }})</a>
            {%- endif -%}
          </div>

          <facet-filters-form>
            <form id="FacetFiltersForm" class="volt-sidebar__form">

              {%- for filter in collection.filters -%}
                {%- assign filter_active_count = filter.active_values.size -%}
                <details
                  id="Details-{{ filter.param_name | escape }}-{{ section.id }}"
                  class="volt-filter-group js-filter"
                  open
                >
                  <summary class="volt-filter-group__toggle facets__summary">
                    <span class="volt-filter-group__name">{{ filter.label | escape }}</span>
                    {%- if filter_active_count > 0 -%}
                      <span class="volt-filter-group__count has-active">{{ filter_active_count }}</span>
                    {%- else -%}
                      <span class="volt-filter-group__count"></span>
                    {%- endif -%}
                    <svg class="volt-filter-group__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path d="M2 4l4 4 4-4"/>
                    </svg>
                  </summary>

                  <div class="volt-filter-group__body facets-wrap">
                    {%- if filter.type == 'list' or filter.type == 'boolean' -%}
                      <ul class="facets__list list-unstyled" role="list">
                        {%- for value in filter.values -%}
                          <li>
                            <label class="volt-filter-check" for="Filter-{{ filter.param_name | escape }}-{{ forloop.index }}-{{ section.id }}">
                              <input
                                type="checkbox"
                                id="Filter-{{ filter.param_name | escape }}-{{ forloop.index }}-{{ section.id }}"
                                name="{{ value.param_name }}"
                                value="{{ value.value }}"
                                {% if value.active %}checked{% endif %}
                                {% if value.count == 0 and value.active == false %}disabled{% endif %}
                              >
                              <span class="volt-filter-check__label">{{ value.label | escape }}</span>
                              <span class="volt-filter-check__count">({{ value.count }})</span>
                            </label>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- elsif filter.type == 'price_range' -%}
                      <div class="volt-filter-price__inputs">
                        <div class="volt-filter-price__field">
                          <label for="Filter-{{ filter.param_name | escape }}-GTE-{{ section.id }}">Min</label>
                          <input
                            class="volt-filter-price__input"
                            id="Filter-{{ filter.param_name | escape }}-GTE-{{ section.id }}"
                            name="{{ filter.min_value.param_name }}"
                            {%- if filter.min_value.value -%}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{%- endif -%}
                            type="number"
                            placeholder="0"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            inputmode="decimal"
                          >
                        </div>
                        <div class="volt-filter-price__field">
                          <label for="Filter-{{ filter.param_name | escape }}-LTE-{{ section.id }}">Max</label>
                          <input
                            class="volt-filter-price__input"
                            id="Filter-{{ filter.param_name | escape }}-LTE-{{ section.id }}"
                            name="{{ filter.max_value.param_name }}"
                            {%- if filter.max_value.value -%}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{%- endif -%}
                            type="number"
                            placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            inputmode="decimal"
                          >
                        </div>
                      </div>
                    {%- endif -%}
                  </div>

                </details>
              {%- endfor -%}

              {%- comment -%} Hidden sort field so both forms stay synced {%- endcomment -%}
              <input type="hidden" name="sort_by" value="{{ sort_by }}">

            </form>
          </facet-filters-form>

        </aside>
      {%- endif -%}

      {%- comment -%} ── Main content ── {%- endcomment -%}
      <div class="volt-collection__main">

        {%- comment -%} Mobile filter trigger bar {%- endcomment -%}
        <div class="volt-filter-mobile-bar">
          <button
            class="volt-filter-mobile-btn mobile-facets__open"
            aria-controls="FacetFiltersDrawer"
            aria-expanded="false"
            aria-label="Show filters"
            type="button"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="4" y1="6" x2="20" y2="6"/>
              <line x1="8" y1="12" x2="16" y2="12"/>
              <line x1="11" y1="18" x2="13" y2="18"/>
            </svg>
            Filters
            {%- assign mobile_active = 0 -%}
            {%- for filter in collection.filters -%}
              {%- assign mobile_active = mobile_active | plus: filter.active_values.size -%}
            {%- endfor -%}
            {%- if mobile_active > 0 -%}
              <span class="mobile-facets__count">({{ mobile_active }})</span>
            {%- endif -%}
          </button>

          {%- comment -%} Active filters — mobile {%- endcomment -%}
          <div class="active-facets-mobile volt-active-filters" style="padding:0">
            {%- for filter in collection.filters -%}
              {%- for value in filter.active_values -%}
                <a href="{{ value.url_to_remove }}" class="js-facet-remove" aria-label="Remove: {{ value.label | escape }}">
                  {{- value.label | escape -}}
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M1 1l8 8M9 1L1 9"/>
                  </svg>
                </a>
              {%- endfor -%}
            {%- endfor -%}
          </div>
        </div>

        {%- comment -%} Top bar: count + sort + view toggle {%- endcomment -%}
        <div class="volt-collection__bar">
          <p class="volt-collection__count" role="status" id="ProductCount">
            {%- if collection.results_count -%}
              {{ 'products.facets.product_count_simple' | t: count: collection.results_count }}
            {%- else -%}
              {{ 'products.facets.product_count_simple' | t: count: collection.products_count }}
            {%- endif -%}
          </p>
          <span id="ProductCountDesktop" class="sr-only" aria-live="polite">
            {%- if collection.results_count -%}
              {{ collection.results_count }}
            {%- else -%}
              {{ collection.products_count }}
            {%- endif -%}
          </span>

          <div class="volt-collection__bar-right">
            {%- comment -%} Sort {%- endcomment -%}
            <div class="sorting">
              <facet-filters-form>
                <form id="FacetSortForm" class="volt-sort-form">
                  <label for="SortBy-{{ section.id }}">Sort</label>
                  <div style="position:relative">
                    <select
                      name="sort_by"
                      id="SortBy-{{ section.id }}"
                      class="volt-sort-select"
                      aria-describedby="a11y-refresh-page-message"
                    >
                      {%- for option in collection.sort_options -%}
                        <option
                          value="{{ option.value | escape }}"
                          {% if option.value == sort_by %}selected="selected"{% endif %}
                        >
                          {{ option.name | escape }}
                        </option>
                      {%- endfor -%}
                    </select>
                    <svg class="volt-sort-caret" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path d="M1 3l4 4 4-4"/>
                    </svg>
                  </div>
                  <input type="hidden" name="sort_by" value="{{ sort_by }}">
                </form>
              </facet-filters-form>
            </div>

            {%- comment -%} View toggle {%- endcomment -%}
            <div class="volt-view-toggle" role="group" aria-label="Product view">
              <button class="volt-view-toggle__btn is-active" data-view="grid-3" aria-label="3 column grid" aria-pressed="true" type="button">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
                  <rect x="0" y="0" width="4" height="4"/><rect x="5" y="0" width="4" height="4"/><rect x="10" y="0" width="4" height="4"/>
                  <rect x="0" y="5" width="4" height="4"/><rect x="5" y="5" width="4" height="4"/><rect x="10" y="5" width="4" height="4"/>
                  <rect x="0" y="10" width="4" height="4"/><rect x="5" y="10" width="4" height="4"/><rect x="10" y="10" width="4" height="4"/>
                </svg>
              </button>
              <button class="volt-view-toggle__btn" data-view="grid-2" aria-label="2 column grid" aria-pressed="false" type="button">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
                  <rect x="0" y="0" width="6" height="6"/><rect x="8" y="0" width="6" height="6"/>
                  <rect x="0" y="8" width="6" height="6"/><rect x="8" y="8" width="6" height="6"/>
                </svg>
              </button>
              <button class="volt-view-toggle__btn" data-view="list" aria-label="List view" aria-pressed="false" type="button">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
                  <rect x="0" y="0" width="14" height="3"/>
                  <rect x="0" y="5" width="14" height="3"/>
                  <rect x="0" y="10" width="14" height="3"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        {%- comment -%} Product grid — Section Rendering API target {%- endcomment -%}
        <div id="ProductGridContainer">
          {%- if collection.products.size == 0 -%}
            <div class="volt-collection__empty collection">
              <p class="volt-collection__empty-title">No products found</p>
              <p class="volt-collection__empty-text">Try adjusting or clearing your filters.</p>
              <a href="{{ collection.url }}" class="volt-btn volt-btn--secondary">Clear filters</a>
            </div>

          {%- else -%}
            <div
              class="volt-collection__grid collection"
              id="product-grid"
              data-id="{{ section.id }}"
            >
              {%- for product in collection.products -%}
                {%- render 'volt-product-card', product: product, thirty_days_ago: thirty_days_ago -%}
              {%- endfor -%}
            </div>

            {%- if paginate.pages > 1 -%}
              <div class="volt-collection__pagination">
                {%- render 'pagination', paginate: paginate, anchor: '' -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>

      </div>{%- comment -%} /.volt-collection__main {%- endcomment -%}

    </div>{%- comment -%} /.volt-collection__layout {%- endcomment -%}
  </div>{%- comment -%} /.volt-container {%- endcomment -%}
</div>{%- comment -%} /.volt-collection {%- endcomment -%}

{%- comment -%} ── Mobile filter drawer (menu-drawer required by facets.js) ── {%- endcomment -%}
<menu-drawer id="FacetFiltersDrawer" data-breakpoint="mobile">
  <details id="FacetFiltersDrawerDetails">
    <summary class="sr-only" aria-expanded="false">Filters</summary>

    <div class="volt-filter-drawer-panel" id="FacetFiltersFormMobilePanel" role="dialog" aria-modal="true" aria-labelledby="mobile-filters-heading">

      <div class="volt-filter-drawer-header">
        <p class="volt-filter-drawer-title" id="mobile-filters-heading">Filters</p>
        <button class="volt-filter-drawer-close" aria-label="Close filters" type="button">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M1 1l14 14M15 1L1 15"/>
          </svg>
        </button>
      </div>

      <div class="volt-filter-drawer-body">
        <facet-filters-form>
          <form id="FacetFiltersFormMobile" class="volt-sidebar__form">

            {%- for filter in collection.filters -%}
              <details
                id="Mobile-Details-{{ filter.param_name | escape }}-{{ section.id }}"
                class="volt-filter-group js-filter"
                open
              >
                <summary class="volt-filter-group__toggle facets__summary">
                  <span class="volt-filter-group__name">{{ filter.label | escape }}</span>
                  <svg class="volt-filter-group__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M2 4l4 4 4-4"/>
                  </svg>
                </summary>

                <div class="volt-filter-group__body facets-wrap">
                  {%- if filter.type == 'list' or filter.type == 'boolean' -%}
                    <ul class="facets__list mobile-facets__list list-unstyled" role="list">
                      {%- for value in filter.values -%}
                        <li>
                          <label class="volt-filter-check" for="Mobile-Filter-{{ filter.param_name | escape }}-{{ forloop.index }}-{{ section.id }}">
                            <input
                              class="mobile-facets__checkbox"
                              type="checkbox"
                              id="Mobile-Filter-{{ filter.param_name | escape }}-{{ forloop.index }}-{{ section.id }}"
                              name="{{ value.param_name }}"
                              value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}
                            >
                            <span class="volt-filter-check__label">{{ value.label | escape }}</span>
                            <span class="volt-filter-check__count">({{ value.count }})</span>
                          </label>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- elsif filter.type == 'price_range' -%}
                    <div class="volt-filter-price__inputs">
                      <div class="volt-filter-price__field">
                        <label for="Mobile-Filter-{{ filter.param_name | escape }}-GTE-{{ section.id }}">Min</label>
                        <input
                          class="volt-filter-price__input"
                          id="Mobile-Filter-{{ filter.param_name | escape }}-GTE-{{ section.id }}"
                          name="{{ filter.min_value.param_name }}"
                          {%- if filter.min_value.value -%}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{%- endif -%}
                          type="number"
                          placeholder="0"
                          min="0"
                          max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          inputmode="decimal"
                        >
                      </div>
                      <div class="volt-filter-price__field">
                        <label for="Mobile-Filter-{{ filter.param_name | escape }}-LTE-{{ section.id }}">Max</label>
                        <input
                          class="volt-filter-price__input"
                          id="Mobile-Filter-{{ filter.param_name | escape }}-LTE-{{ section.id }}"
                          name="{{ filter.max_value.param_name }}"
                          {%- if filter.max_value.value -%}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{%- endif -%}
                          type="number"
                          placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          min="0"
                          max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          inputmode="decimal"
                        >
                      </div>
                    </div>
                  {%- endif -%}
                </div>
              </details>
            {%- endfor -%}

            <input type="hidden" name="sort_by" value="{{ sort_by }}">

          </form>
        </facet-filters-form>
      </div>

      <div class="volt-filter-drawer-footer">
        <button
          class="volt-btn volt-btn--primary"
          style="width:100%"
          type="button"
          onclick="this.closest('details').removeAttribute('open')"
        >
          View {{ collection.products_count }} products
        </button>
      </div>

    </div>
  </details>
</menu-drawer>

{%- comment -%} View toggle + mobile drawer JS {%- endcomment -%}
<script>
(function () {
  /* ── View toggle ── */
  var grid = document.getElementById('product-grid');
  if (grid) {
    document.querySelectorAll('.volt-view-toggle__btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var view = btn.dataset.view;
        document.querySelectorAll('.volt-view-toggle__btn').forEach(function (b) {
          b.classList.remove('is-active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('is-active');
        btn.setAttribute('aria-pressed', 'true');
        grid.classList.remove('view-2col', 'view-list');
        if (view === 'grid-2') grid.classList.add('view-2col');
        if (view === 'list') grid.classList.add('view-list');
      });
    });
  }

  /* ── Mobile drawer ── */
  var openBtn = document.querySelector('.volt-filter-mobile-btn');
  var drawer = document.getElementById('FacetFiltersDrawerDetails');
  var closeBtn = document.querySelector('.volt-filter-drawer-close');
  var overlay;

  function openDrawer() {
    if (!drawer) return;
    drawer.setAttribute('open', '');
    document.body.style.overflow = 'hidden';
    if (openBtn) openBtn.setAttribute('aria-expanded', 'true');
  }

  function closeDrawer() {
    if (!drawer) return;
    drawer.removeAttribute('open');
    document.body.style.overflow = '';
    if (openBtn) openBtn.setAttribute('aria-expanded', 'false');
  }

  if (openBtn) openBtn.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);

  /* Close on overlay click */
  var drawerPanel = document.querySelector('.volt-filter-drawer-panel');
  if (drawerPanel) {
    drawerPanel.parentElement && drawerPanel.parentElement.addEventListener('click', function (e) {
      if (!drawerPanel.contains(e.target)) closeDrawer();
    });
  }

  /* Close on Escape */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer && drawer.hasAttribute('open')) closeDrawer();
  });
})();
</script>

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection product grid",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filtering",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    }
  ]
}
{% endschema %}
