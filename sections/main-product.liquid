{{ 'volt-product.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-input.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'volt-wishlist.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'volt-compare.js' | asset_url }}" defer="defer"></script>

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id

  assign has_sale = false
  assign save_percent = 0
  if current_variant.compare_at_price > current_variant.price
    assign has_sale = true
    assign save_amount = current_variant.compare_at_price | minus: current_variant.price
    assign save_percent = save_amount | times: 100 | divided_by: current_variant.compare_at_price
  endif

  assign thirty_days_ago = 'now' | date: '%s' | minus: 2592000
  assign product_timestamp = product.created_at | date: '%s'
  assign product_is_new = false
  if product_timestamp > thirty_days_ago
    assign product_is_new = true
  endif

  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'

  assign spec_processor = product.metafields.specs.processor.value
  assign spec_ram = product.metafields.specs.ram.value
  assign spec_storage = product.metafields.specs.storage.value
  assign spec_display = product.metafields.specs.display.value
  assign spec_battery = product.metafields.specs.battery.value
  assign spec_connectivity = product.metafields.specs.connectivity.value
  assign spec_weight = product.metafields.specs.weight.value
  assign spec_warranty = product.metafields.specs.warranty.value

  assign has_specs = false
  if spec_processor != blank or spec_ram != blank or spec_storage != blank or spec_display != blank or spec_battery != blank or spec_connectivity != blank or spec_weight != blank or spec_warranty != blank
    assign has_specs = true
  endif

  assign breadcrumb_col = collection | default: product.collections.first
-%}

<product-info
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>

  <div class="volt-product">
    <div class="volt-container">

      {%- comment -%} Breadcrumb {%- endcomment -%}
      <nav class="volt-product__breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="volt-product__breadcrumb-sep" aria-hidden="true">/</span>
        {%- if breadcrumb_col != blank -%}
          <a href="{{ breadcrumb_col.url }}">{{ breadcrumb_col.title | escape }}</a>
          <span class="volt-product__breadcrumb-sep" aria-hidden="true">/</span>
        {%- endif -%}
        <span class="volt-product__breadcrumb-current" aria-current="page">
          {{- product.title | escape -}}
        </span>
      </nav>

      {%- comment -%} Main grid {%- endcomment -%}
      <div class="volt-product__grid">

        {%- comment -%} ── LEFT: Media gallery ── {%- endcomment -%}
        <div class="volt-product__media">
          {%- render 'product-media-gallery', variant_images: variant_images -%}
        </div>

        {%- comment -%} ── RIGHT: Info column ── {%- endcomment -%}
        <div class="volt-product__info">

          {%- comment -%} Vendor + badges {%- endcomment -%}
          <div class="volt-product__meta">
            {%- if product.vendor != blank -%}
              <span class="volt-product__vendor">{{ product.vendor | escape }}</span>
            {%- endif -%}
            {%- if product.available == false -%}
              <span class="volt-badge volt-badge--soldout">Sold Out</span>
            {%- elsif has_sale -%}
              <span class="volt-badge volt-badge--sale">Sale</span>
            {%- elsif product_is_new -%}
              <span class="volt-badge volt-badge--new">New</span>
            {%- endif -%}
          </div>

          {%- comment -%} Title {%- endcomment -%}
          <h1 class="volt-product__title">{{ product.title | escape }}</h1>

          {%- comment -%} Judge.me rating badge {%- endcomment -%}
          {%- if section.settings.show_reviews_tab -%}
            <div class="volt-product__rating" id="volt-product-rating-{{ section.id }}">
              <span
                class="jdgm-prev-badge"
                data-id="{{ product.id }}"
                data-position="left"
              ></span>
            </div>
          {%- endif -%}

          {%- comment -%} Price {%- endcomment -%}
          <div class="volt-product__price-wrap" id="price-{{ section.id }}" role="status">
            <div class="price__container">
              {%- render 'price', product: product, use_variant: true, show_badges: false -%}
              {%- if has_sale and save_percent > 0 -%}
                <span class="volt-product__save">Save {{ save_percent }}%</span>
              {%- endif -%}
            </div>
            {%- if cart.taxes_included -%}
              <p class="volt-product__tax-note">Tax included</p>
            {%- endif -%}
          </div>

          {%- comment -%} Variant picker {%- endcomment -%}
          {%- unless product.has_only_default_variant -%}
            <variant-radios
              id="volt-variant-radios-{{ section.id }}"
              class="volt-product__options no-js-hidden"
              data-section="{{ section.id }}"
              data-url="{{ product.url }}"
              data-update-url="false"
            >
              {%- for option in product.options_with_values -%}
                <fieldset class="volt-product__option">
                  <legend class="volt-product__option-label">
                    {{ option.name }}:
                    <span>
                      {{- product.selected_or_first_available_variant.options[forloop.index0] -}}
                    </span>
                  </legend>
                  <div class="volt-product__option-values">
                    {%- for value in option.values -%}
                      {%- liquid
                        assign option_disabled = true
                        for variant in product.variants
                          if variant.available and variant.options[forloop.parentloop.index0] == value
                            assign option_disabled = false
                          endif
                        endfor
                      -%}
                      <input
                        type="radio"
                        id="volt-option-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                        name="{{ option.name }}"
                        value="{{ value | escape }}"
                        class="sr-only volt-product__option-input"
                        form="{{ product_form_id }}"
                        {% if product.selected_or_first_available_variant.options[option.position | minus: 1] == value %}
                          checked
                        {% endif %}
                        {% if option_disabled %}disabled{% endif %}
                      >
                      <label
                        for="volt-option-{{ section.id }}-{{ option.position }}-{{ forloop.index }}"
                        class="volt-product__option-btn{% if option_disabled %} is-disabled{% endif %}"
                      >
                        {{- value | escape -}}
                      </label>
                    {%- endfor -%}
                  </div>
                </fieldset>
              {%- endfor -%}

              <script type="application/json">
                {{ product.variants | json }}
              </script>
            </variant-radios>

            <noscript>
              <div class="volt-product__options">
                <label for="volt-noscript-variant-{{ section.id }}" class="volt-product__option-label">
                  {{ 'products.product.product_variants' | t }}
                </label>
                <select
                  id="volt-noscript-variant-{{ section.id }}"
                  name="id"
                  form="{{ product_form_id }}"
                  style="margin-top: 8px; padding: 10px; border: 1.5px solid var(--volt-border); font-family: var(--volt-font-body); width: 100%;"
                >
                  {%- for variant in product.variants -%}
                    <option
                      value="{{ variant.id }}"
                      {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                      {% unless variant.available %}disabled{% endunless %}
                    >
                      {{ variant.title }}{% unless variant.available %} — {{ 'products.product.sold_out' | t }}{% endunless %}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            </noscript>
          {%- endunless -%}

          {%- comment -%} Product form: qty + ATC {%- endcomment -%}
          <product-form
            data-section-id="{{ section.id }}"
            data-product-id="{{ product.id }}"
            data-product-url="{{ product.url }}"
          >
            <form
              action="{{ routes.cart_add_url }}"
              method="post"
              id="{{ product_form_id }}"
              novalidate
            >
              <input type="hidden" name="form_type" value="product">
              <input type="hidden" name="utf8" value="✓">
              <input
                type="hidden"
                name="id"
                id="{{ product_form_id }}-variant"
                value="{{ current_variant.id }}"
              >

              {%- comment -%} Quantity + ATC row {%- endcomment -%}
              <div class="volt-product__form-row">
                <quantity-input class="quantity">
                  <button
                    class="quantity__button no-js-hidden"
                    name="minus"
                    type="button"
                    aria-label="{{ 'products.product.quantity.decrease' | t: product: product.title }}"
                  >−</button>
                  <input
                    class="quantity__input"
                    type="number"
                    name="quantity"
                    id="Quantity-{{ section.id }}"
                    min="1"
                    value="1"
                    inputmode="numeric"
                    autocomplete="off"
                    aria-label="{{ 'products.product.quantity.label' | t }}"
                  >
                  <button
                    class="quantity__button no-js-hidden"
                    name="plus"
                    type="button"
                    aria-label="{{ 'products.product.quantity.increase' | t: product: product.title }}"
                  >+</button>
                </quantity-input>

                <button
                  type="submit"
                  name="add"
                  id="product-form-submit-{{ section.id }}"
                  class="volt-btn volt-btn--primary volt-btn--lg volt-product__atc"
                  {% if current_variant.available == false %}aria-disabled="true"{% endif %}
                >
                  <span class="volt-product__atc-text">
                    {%- if current_variant.available -%}
                      Add to Cart
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    {%- else -%}
                      Sold Out
                    {%- endif -%}
                  </span>
                  <span class="volt-product__atc-spinner" aria-hidden="true">
                    <span class="volt-spinner"></span>
                  </span>
                </button>
              </div>

              {%- comment -%} Error message (populated by product-form.js) {%- endcomment -%}
              <div
                class="product-form__error-message-wrapper"
                role="alert"
                hidden
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" flex-shrink="0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span class="product-form__error-message"></span>
              </div>

            </form>
          </product-form>

          {%- comment -%} Wishlist + compare {%- endcomment -%}
          <div class="volt-product__secondary-actions">
            <button
              type="button"
              class="volt-product__action-btn volt-product__action-btn--wishlist"
              data-wishlist-btn
              data-product-id="{{ product.id }}"
              aria-label="Add {{ product.title | escape }} to wishlist"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              Wishlist
            </button>
            <button
              type="button"
              class="volt-product__action-btn volt-product__action-btn--compare"
              data-compare-btn
              data-product-id="{{ product.id }}"
              data-product-title="{{ product.title | escape }}"
              aria-label="Add {{ product.title | escape }} to compare"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              Compare
            </button>
          </div>

          {%- comment -%} Trust badges {%- endcomment -%}
          <div class="volt-product__trust" aria-label="Purchase guarantees">
            {%- if section.settings.trust_1 != blank -%}
              <div class="volt-product__trust-item">
                <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {{ section.settings.trust_1 | escape }}
              </div>
            {%- endif -%}
            {%- if section.settings.trust_2 != blank -%}
              <div class="volt-product__trust-item">
                <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {{ section.settings.trust_2 | escape }}
              </div>
            {%- endif -%}
            {%- if section.settings.trust_3 != blank -%}
              <div class="volt-product__trust-item">
                <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {{ section.settings.trust_3 | escape }}
              </div>
            {%- endif -%}
            {%- if section.settings.trust_4 != blank -%}
              <div class="volt-product__trust-item">
                <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {{ section.settings.trust_4 | escape }}
              </div>
            {%- endif -%}
          </div>

        </div>
        {%- comment -%} /.volt-product__info {%- endcomment -%}

      </div>
      {%- comment -%} /.volt-product__grid {%- endcomment -%}

      {%- comment -%} ── Tabs: Description | Specs | Reviews ── {%- endcomment -%}
      <volt-product-tabs>
        <div class="volt-product__tabs-section">

          <div class="volt-product__tab-nav" role="tablist" aria-label="Product information">

            <button
              class="volt-product__tab-btn is-active"
              role="tab"
              data-tab="description"
              aria-selected="true"
              aria-controls="volt-panel-description-{{ section.id }}"
              id="volt-tab-description-{{ section.id }}"
            >Description</button>

            {%- if has_specs -%}
              <button
                class="volt-product__tab-btn"
                role="tab"
                data-tab="specs"
                aria-selected="false"
                aria-controls="volt-panel-specs-{{ section.id }}"
                id="volt-tab-specs-{{ section.id }}"
              >Specifications</button>
            {%- endif -%}

            {%- if section.settings.show_reviews_tab -%}
              <button
                class="volt-product__tab-btn"
                role="tab"
                data-tab="reviews"
                aria-selected="false"
                aria-controls="volt-panel-reviews-{{ section.id }}"
                id="volt-tab-reviews-{{ section.id }}"
              >
                Reviews
                <span class="volt-product__tab-count jdgm-prev-badge__count" data-id="{{ product.id }}"></span>
              </button>
            {%- endif -%}

          </div>

          {%- comment -%} Description {%- endcomment -%}
          <div
            class="volt-product__tab-panel"
            id="volt-panel-description-{{ section.id }}"
            role="tabpanel"
            aria-labelledby="volt-tab-description-{{ section.id }}"
          >
            {%- if product.description != blank -%}
              <div class="volt-product__description rte">
                {{ product.description }}
              </div>
            {%- else -%}
              <p class="volt-product__specs-empty">No description provided.</p>
            {%- endif -%}
          </div>

          {%- comment -%} Specifications {%- endcomment -%}
          {%- if has_specs -%}
            <div
              class="volt-product__tab-panel"
              id="volt-panel-specs-{{ section.id }}"
              role="tabpanel"
              aria-labelledby="volt-tab-specs-{{ section.id }}"
              hidden
            >
              <div class="volt-specs" style="max-width: 640px;">
                {%- if spec_processor != blank -%}
                  <div class="volt-specs__row">
                    <div class="volt-specs__key">Processor</div>
                    <div class="volt-specs__val">{{ spec_processor }}</div>
                  </div>
                {%- endif -%}
                {%- if spec_ram != blank -%}
                  <div class="volt-specs__row">
                    <div class="volt-specs__key">RAM</div>
                    <div class="volt-specs__val">{{ spec_ram }}</div>
                  </div>
                {%- endif -%}
                {%- if spec_storage != blank -%}
                  <div class="volt-specs__row">
                    <div class="volt-specs__key">Storage</div>
                    <div class="volt-specs__val">{{ spec_storage }}</div>
                  </div>
                {%- endif -%}
                {%- if spec_display != blank -%}
                  <div class="volt-specs__row">
                    <div class="volt-specs__key">Display</div>
                    <div class="volt-specs__val">{{ spec_display }}</div>
                  </div>
                {%- endif -%}
                {%- if spec_battery != blank -%}
                  <div class="volt-specs__row">
                    <div class="volt-specs__key">Battery</div>
                    <div class="volt-specs__val">{{ spec_battery }}</div>
                  </div>
                {%- endif -%}
                {%- if spec_connectivity != blank -%}
                  <div class="volt-specs__row">
                    <div class="volt-specs__key">Connectivity</div>
                    <div class="volt-specs__val">{{ spec_connectivity }}</div>
                  </div>
                {%- endif -%}
                {%- if spec_weight != blank -%}
                  <div class="volt-specs__row">
                    <div class="volt-specs__key">Weight</div>
                    <div class="volt-specs__val">{{ spec_weight }}</div>
                  </div>
                {%- endif -%}
                {%- if spec_warranty != blank -%}
                  <div class="volt-specs__row">
                    <div class="volt-specs__key">Warranty</div>
                    <div class="volt-specs__val">{{ spec_warranty }}</div>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Reviews (Judge.me) {%- endcomment -%}
          {%- if section.settings.show_reviews_tab -%}
            <div
              class="volt-product__tab-panel"
              id="volt-panel-reviews-{{ section.id }}"
              role="tabpanel"
              aria-labelledby="volt-tab-reviews-{{ section.id }}"
              hidden
            >
              <div class="volt-product__reviews-wrap">
                <div
                  class="jdgm-widget jdgm-review-widget"
                  data-id="{{ product.id }}"
                ></div>
              </div>
            </div>
          {%- endif -%}

        </div>
      </volt-product-tabs>

    </div>
    {%- comment -%} /.volt-container {%- endcomment -%}
  </div>
  {%- comment -%} /.volt-product {%- endcomment -%}

</product-info>

{%- comment -%} ── Sticky ATC bar ── {%- endcomment -%}
{%- if section.settings.show_sticky_atc -%}
  <div
    class="volt-sticky-atc"
    id="volt-sticky-atc-{{ section.id }}"
    aria-hidden="true"
    role="complementary"
    aria-label="Quick add to cart"
  >
    <div class="volt-container">
      <div class="volt-sticky-atc__inner">
        {%- if product.featured_image != blank -%}
          <img
            class="volt-sticky-atc__img"
            src="{{ product.featured_image | image_url: width: 88 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="44"
            height="44"
            loading="lazy"
          >
        {%- endif -%}

        <span class="volt-sticky-atc__title">{{ product.title | escape }}</span>

        <span class="volt-sticky-atc__price" id="volt-sticky-price-{{ section.id }}">
          {{- current_variant.price | money_with_currency -}}
        </span>

        <button
          type="button"
          id="volt-sticky-atc-btn-{{ section.id }}"
          class="volt-btn volt-btn--primary volt-sticky-atc__btn"
          aria-label="Add {{ product.title | escape }} to cart"
        >
          Add to Cart
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        </button>
      </div>
    </div>
  </div>
{%- endif -%}

<script>
  // ── Sticky ATC ──────────────────────────────────────────────────────────────
  (function () {
    const atcBtn = document.getElementById('product-form-submit-{{ section.id }}');
    const stickyBar = document.getElementById('volt-sticky-atc-{{ section.id }}');
    const stickyBtn = document.getElementById('volt-sticky-atc-btn-{{ section.id }}');

    if (!atcBtn || !stickyBar) return;

    const observer = new IntersectionObserver(
      function (entries) {
        const entry = entries[0];
        stickyBar.classList.toggle('is-visible', !entry.isIntersecting);
        stickyBar.setAttribute('aria-hidden', entry.isIntersecting ? 'true' : 'false');
      },
      { rootMargin: '0px 0px -60px 0px' }
    );

    observer.observe(atcBtn);

    if (stickyBtn) {
      stickyBtn.addEventListener('click', function () {
        const form = document.getElementById('{{ product_form_id }}');
        if (form) {
          if (typeof form.requestSubmit === 'function') {
            form.requestSubmit();
          } else {
            form.submit();
          }
        }
      });
    }
  })();

  // ── Product tabs ────────────────────────────────────────────────────────────
  if (!customElements.get('volt-product-tabs')) {
    class VoltProductTabs extends HTMLElement {
      connectedCallback() {
        this.addEventListener('click', (e) => {
          const btn = e.target.closest('[data-tab]');
          if (!btn) return;

          const tabId = btn.dataset.tab;
          const section = '{{ section.id }}';

          this.querySelectorAll('[data-tab]').forEach((b) => {
            b.classList.remove('is-active');
            b.setAttribute('aria-selected', 'false');
          });
          btn.classList.add('is-active');
          btn.setAttribute('aria-selected', 'true');

          this.querySelectorAll('[role="tabpanel"]').forEach((panel) => {
            panel.hidden = panel.id !== `volt-panel-${tabId}-${section}`;
          });
        });
      }
    }
    customElements.define('volt-product-tabs', VoltProductTabs);
  }
</script>

{% schema %}
{
  "name": "Product information",
  "tag": "section",
  "class": "section-volt-product",
  "settings": [
    {
      "type": "header",
      "content": "Trust badges"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust badge 1",
      "default": "Free Metro Delivery on orders over ₱2,000"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust badge 2",
      "default": "1-Year Warranty included"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust badge 3",
      "default": "30-Day hassle-free returns"
    },
    {
      "type": "text",
      "id": "trust_4",
      "label": "Trust badge 4",
      "default": "Secure checkout — SSL encrypted"
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "checkbox",
      "id": "show_sticky_atc",
      "label": "Show sticky Add to Cart bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_reviews_tab",
      "label": "Show Reviews tab (Judge.me)",
      "default": true,
      "info": "Requires Judge.me app to be installed."
    }
  ],
