{{ 'volt-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}
<script src="{{ 'quantity-input.js' | asset_url }}" defer="defer"></script>

<cart-items
  class="volt-cart-items-section{% if cart == empty %} is-empty{% endif %}"
  id="volt-cart-items"
>
  <div class="volt-container">

    {%- comment -%} Page header {%- endcomment -%}
    <div class="volt-cart__header">
      <h1 class="volt-cart__title">
        Your Cart
        {%- if cart.item_count > 0 -%}
          <span class="volt-cart__count">({{ cart.item_count }})</span>
        {%- endif -%}
      </h1>
      <a href="{{ routes.all_products_collection_url }}" class="volt-cart__continue">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Continue Shopping
      </a>
    </div>

    {%- comment -%} Empty state {%- endcomment -%}
    <div class="volt-cart__empty">
      <svg class="volt-cart__empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      <p class="volt-cart__empty-title">Your cart is empty</p>
      <p class="volt-cart__empty-sub">Add some products to get started.</p>
      <a href="{{ routes.all_products_collection_url }}" class="volt-btn volt-btn--primary">
        Shop Now
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>

      {%- if shop.customer_accounts_enabled and customer == null -%}
        <p class="volt-cart__login-note">
          {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} Cart form {%- endcomment -%}
    <form
      action="{{ routes.cart_url }}"
      class="volt-cart__form critical-hidden"
      method="post"
      id="cart"
    >
      <div id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">
          {%- if cart != empty -%}

            {%- comment -%} Column headings — desktop {%- endcomment -%}
            <div class="volt-cart__thead" aria-hidden="true">
              <span class="volt-cart__thead-product">Product</span>
              <span class="volt-cart__thead-qty">Quantity</span>
              <span class="volt-cart__thead-total">Total</span>
            </div>

            {%- for item in cart.items -%}
              {%- liquid
                assign has_qty_rules = false
                if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                  assign has_qty_rules = true
                endif
              -%}

              <div
                class="volt-cart__row{% if item.parent_relationship.parent != null %} volt-cart__row--nested{% endif %}"
                id="CartItem-{{ item.index | plus: 1 }}"
              >

                {%- comment -%} Image {%- endcomment -%}
                <div class="volt-cart__row-media">
                  {%- if item.image -%}
                    <a href="{{ item.url }}" aria-hidden="true" tabindex="-1" class="volt-cart__row-img-link">
                      <img
                        src="{{ item.image | image_url: width: 200 }}"
                        alt="{{ item.image.alt | escape }}"
                        width="100"
                        height="{{ 100 | divided_by: item.image.aspect_ratio | ceil }}"
                        loading="lazy"
                        class="volt-cart__row-img"
                      >
                    </a>
                  {%- endif -%}
                </div>

                {%- comment -%} Info {%- endcomment -%}
                <div class="volt-cart__row-info">
                  {%- if item.product.vendor != blank -%}
                    <p class="volt-cart__row-vendor">{{ item.product.vendor | escape }}</p>
                  {%- endif -%}

                  <a href="{{ item.url }}" class="volt-cart__row-name">
                    {{- item.product.title | escape -}}
                  </a>

                  {%- comment -%} Variant options {%- endcomment -%}
                  {%- unless item.product.has_only_default_variant and item.properties.size == 0 and item.selling_plan_allocation == null -%}
                    <dl class="volt-cart__row-meta">
                      {%- unless item.product.has_only_default_variant -%}
                        {%- for option in item.options_with_values -%}
                          <div class="volt-cart__row-meta-item">
                            <dt>{{ option.name }}:</dt>
                            <dd>{{ option.value }}</dd>
                          </div>
                        {%- endfor -%}
                      {%- endunless -%}
                      {%- for property in item.properties -%}
                        {%- assign property_first_char = property.first | slice: 0 -%}
                        {%- if property.last != blank and property_first_char != '_' -%}
                          <div class="volt-cart__row-meta-item">
                            <dt>{{ property.first }}:</dt>
                            <dd>
                              {%- if property.last contains '/uploads/' -%}
                                <a href="{{ property.last }}" target="_blank">{{ property.last | split: '/' | last }}</a>
                              {%- else -%}
                                {{ property.last }}
                              {%- endif -%}
                            </dd>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                      {%- if item.selling_plan_allocation != null -%}
                        <div class="volt-cart__row-meta-item">
                          <dt>Plan:</dt>
                          <dd>{{ item.selling_plan_allocation.selling_plan.name }}</dd>
                        </div>
                      {%- endif -%}
                    </dl>
                  {%- endunless -%}

                  {%- comment -%} Line discounts {%- endcomment -%}
                  {%- if item.line_level_discount_allocations.size > 0 -%}
                    <ul class="volt-cart__row-discounts" role="list">
                      {%- for discount in item.line_level_discount_allocations -%}
                        <li class="volt-cart__row-discount">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                          {{ discount.discount_application.title | escape }}
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                  {%- comment -%} Unit price {%- endcomment -%}
                  {%- if item.variant.available and item.unit_price_measurement -%}
                    <p class="volt-cart__row-unit-price">
                      {{ item.unit_price | money }}
                      <span>/</span>
                      {%- if item.unit_price_measurement.reference_value != 1 -%}
                        {{ item.unit_price_measurement.reference_value }}
                      {%- endif -%}
                      {{ item.unit_price_measurement.reference_unit }}
                    </p>
                  {%- endif -%}

                  {%- comment -%} Per-item price (mobile) {%- endcomment -%}
                  <div class="volt-cart__row-price-mobile" aria-hidden="true">
                    {%- if item.original_price != item.final_price -%}
                      <s class="volt-cart__row-old-price">{{ item.original_price | money }}</s>
                      <span class="volt-cart__row-final-price">{{ item.final_price | money }}</span>
                    {%- else -%}
                      <span class="volt-cart__row-final-price">{{ item.original_price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>

                {%- comment -%} Quantity {%- endcomment -%}
                <div class="volt-cart__row-qty">
                  <label class="sr-only" for="Quantity-{{ item.index | plus: 1 }}">
                    {{ 'products.product.quantity.label' | t }}
                  </label>
                  {%- assign can_update_quantity = item.instructions.can_update_quantity | default: true -%}
                  <quantity-input class="volt-qty-stepper">
                    <button
                      class="volt-qty-stepper__btn"
                      name="minus"
                      type="button"
                      aria-label="{{ 'products.product.quantity.decrease' | t: product: item.product.title | escape }}"
                      {% if can_update_quantity == false %}disabled{% endif %}
                    >−</button>
                    <input
                      class="volt-qty-stepper__input"
                      type="number"
                      name="updates[]"
                      id="Quantity-{{ item.index | plus: 1 }}"
                      value="{{ item.quantity }}"
                      {% # theme-check-disable %}
                      data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                      min="0"
                      data-min="{{ item.variant.quantity_rule.min }}"
                      {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
                      step="{{ item.variant.quantity_rule.increment }}"
                      {% # theme-check-enable %}
                      data-quantity-variant-id="{{ item.variant.id }}"
                      data-index="{{ item.index | plus: 1 }}"
                      aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                      {% if can_update_quantity == false %}disabled{% endif %}
                    >
                    <button
                      class="volt-qty-stepper__btn"
                      name="plus"
                      type="button"
                      aria-label="{{ 'products.product.quantity.increase' | t: product: item.product.title | escape }}"
                      {% if can_update_quantity == false %}disabled{% endif %}
                    >+</button>
                  </quantity-input>

                  {%- assign can_remove = item.instructions.can_remove | default: true -%}
                  <cart-remove-button
                    id="Remove-{{ item.index | plus: 1 }}"
                    data-index="{{ item.index | plus: 1 }}"
                    {% unless can_remove %}class="hidden"{% endunless %}
                  >
                    <a
                      href="{{ item.url_to_remove }}"
                      class="volt-cart__row-remove"
                      aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                      </svg>
                      Remove
                    </a>
                  </cart-remove-button>

                  {%- comment -%} Qty rules note {%- endcomment -%}
                  {%- if has_qty_rules -%}
                    <p class="volt-cart__qty-note">
                      {%- if item.variant.quantity_rule.increment > 1 -%}
                        Multiples of {{ item.variant.quantity_rule.increment }}.
                      {%- endif -%}
                      {%- if item.variant.quantity_rule.min > 1 -%}
                        Min {{ item.variant.quantity_rule.min }}.
                      {%- endif -%}
                      {%- if item.variant.quantity_rule.max != null -%}
                        Max {{ item.variant.quantity_rule.max }}.
                      {%- endif -%}
                    </p>
                  {%- endif -%}

                  {%- comment -%} Line error {%- endcomment -%}
                  <div class="volt-cart__row-error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                    <small class="cart-item__error-text"></small>
                  </div>
                </div>

                {%- comment -%} Line total {%- endcomment -%}
                <div class="volt-cart__row-total" aria-label="Line total">
                  {%- render 'loading-spinner' -%}
                  {%- if item.original_line_price != item.final_line_price -%}
                    <s class="volt-cart__row-old-price">{{ item.original_line_price | money }}</s>
                    <span class="volt-cart__row-final-price">{{ item.final_line_price | money }}</span>
                  {%- else -%}
                    <span class="volt-cart__row-final-price">{{ item.original_line_price | money }}</span>
                  {%- endif -%}
                </div>

              </div>
            {%- endfor -%}

          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Accessibility live regions {%- endcomment -%}
      <p class="sr-only" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p class="sr-only" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">
        {{- 'accessibility.loading' | t -}}
      </p>

    </form>

  </div>
</cart-items>

{% schema %}
{
  "name": "Cart items",
  "settings": []
}
{% endschema %}
