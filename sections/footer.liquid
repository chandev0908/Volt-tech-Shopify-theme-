{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'volt-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_social = false
  if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_twitter_link != blank or settings.social_pinterest_link != blank or settings.social_snapchat_link != blank or settings.social_vimeo_link != blank
    assign has_social = true
  endif
-%}

<footer class="volt-footer" role="contentinfo" aria-label="{{ shop.name }} footer">

  {%- comment -%} ── Top: brand + link columns ── {%- endcomment -%}
  <div class="volt-footer__top">
    <div class="volt-container">
      <div class="volt-footer__grid">

        {%- comment -%} Brand column {%- endcomment -%}
        <div class="volt-footer__brand">
          <a href="{{ routes.root_url }}" class="volt-footer__logo" aria-label="{{ shop.name }} home">
            <span class="volt-footer__logo-v">V</span>OLT<span class="volt-footer__logo-dot">.</span>
          </a>

          {%- if section.settings.brand_tagline != blank -%}
            <p class="volt-footer__tagline">{{ section.settings.brand_tagline | escape }}</p>
          {%- endif -%}

          {%- if section.settings.show_social and has_social -%}
            <div class="volt-footer__social">
              {%- render 'social-icons' -%}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Link / text blocks {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'link_list' -%}
              <div class="volt-footer__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="volt-footer__col-heading">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="volt-footer__links" role="list">
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a
                          href="{{ link.url }}"
                          class="volt-footer__link{% if link.active %} is-active{% endif %}"
                          {% if link.active %}aria-current="page"{% endif %}
                        >
                          {{- link.title | escape -}}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>

            {%- when 'text' -%}
              <div class="volt-footer__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="volt-footer__col-heading">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.subtext != blank -%}
                  <div class="volt-footer__col-text rte">{{ block.settings.subtext }}</div>
                {%- endif -%}
              </div>

            {%- when 'brand_information' -%}
              {%- comment -%} Rendered in brand column above; skip here {%- endcomment -%}

            {%- when '@app' -%}
              {% render block %}

          {%- endcase -%}
        {%- endfor -%}

      </div>
    </div>
  </div>

  {%- comment -%} ── Newsletter band ── {%- endcomment -%}
  {%- if section.settings.newsletter_enable -%}
    <div class="volt-footer__newsletter">
      <div class="volt-container">
        <div class="volt-footer__newsletter-inner">

          <div class="volt-footer__newsletter-copy">
            <p class="volt-footer__newsletter-eyebrow">Newsletter</p>
            <h2 class="volt-footer__newsletter-heading">
              {{- section.settings.newsletter_heading | default: 'Stay in the Loop.' | escape -}}
            </h2>
            {%- if section.settings.newsletter_subtext != blank -%}
              <p class="volt-footer__newsletter-sub">{{ section.settings.newsletter_subtext | escape }}</p>
            {%- endif -%}
          </div>

          <div class="volt-footer__form-wrap">
            {%- form 'customer', id: 'ContactFooter-{{ section.id }}', class: 'volt-footer__form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              {%- if form.posted_successfully? -%}
                <p class="volt-footer__form-success">
                  You're subscribed. Exclusive deals incoming.
                </p>
              {%- else -%}
                <div class="volt-footer__form-row">
                  <label for="FooterEmail-{{ section.id }}" class="sr-only">
                    {{ 'newsletter.label' | t }}
                  </label>
                  <input
                    type="email"
                    name="contact[email]"
                    id="FooterEmail-{{ section.id }}"
                    class="volt-footer__input"
                    placeholder="your@email.com"
                    autocomplete="email"
                    autocorrect="off"
                    autocapitalize="off"
                    required
                    {% if form.errors %}aria-invalid="true" aria-describedby="FooterEmailError-{{ section.id }}"{% endif %}
                  >
                  <button
                    type="submit"
                    name="commit"
                    class="volt-btn volt-btn--primary"
                    aria-label="{{ 'newsletter.button_label' | t }}"
                  >
                    Subscribe
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="9 18 15 12 9 6"/>
                    </svg>
                  </button>
                </div>
                {%- if form.errors -%}
                  <p class="volt-footer__form-error" id="FooterEmailError-{{ section.id }}">
                    {{ form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email }}
                  </p>
                {%- endif -%}
              {%- endif -%}
            {%- endform -%}
          </div>

        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Bottom bar ── {%- endcomment -%}
  <div class="volt-footer__bottom">
    <div class="volt-container">
      <div class="volt-footer__bottom-inner">

        <p class="volt-footer__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}. All rights reserved.
        </p>

        {%- if section.settings.show_policy and shop.policies.size > 0 -%}
          <ul class="volt-footer__policies" role="list">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li>
                  <a href="{{ policy.url }}" class="volt-footer__policy-link">
                    {{- policy.title | escape -}}
                  </a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.payment_enable and shop.enabled_payment_types.size > 0 -%}
          <ul class="volt-footer__payments" role="list" aria-label="Accepted payment methods">
            {%- for type in shop.enabled_payment_types -%}
              <li>{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "About"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Content",
          "default": "<p>Share information about your store with your customers.</p>"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "Brand information",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Brand info is rendered in the logo column. Use the Brand tagline setting instead."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
      "id": "brand_tagline",
      "label": "Brand tagline",
      "default": "Premium electronics for every lifestyle. Your tech, powered up."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true,
      "info": "Configure social links in Theme Settings → Social media."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay in the Loop."
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter subtext",
      "default": "Exclusive deals, new arrivals, and tech news — straight to your inbox."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "label": "Show policy links",
      "default": true
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Shop",
          "menu": "main-menu"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Support",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Company",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
