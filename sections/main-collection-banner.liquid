{{ 'volt-collection.css' | asset_url | stylesheet_tag }}

<div class="volt-collection-banner">
  <div class="volt-container">

    <nav class="volt-collection-banner__breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}" class="volt-collection-banner__crumb">Home</a>
      <span class="volt-collection-banner__sep" aria-hidden="true">›</span>
      <span class="volt-collection-banner__crumb" aria-current="page">{{ collection.title | escape }}</span>
    </nav>

    <h1 class="volt-collection-banner__title">{{ collection.title | escape }}</h1>

    {%- if section.settings.show_collection_description and collection.description != blank -%}
      <div class="volt-collection-banner__desc rte">
        {{ collection.description }}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Collection banner",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "label": "Show description",
      "default": true
    }
  ]
}
{% endschema %}
