{% comment %}
  Renders the Volt cart drawer (slide-out panel).
  Triggered when cart_type = 'drawer' in theme settings.
  Usage: {% render 'cart-drawer' %}
{% endcomment %}

{{ 'volt-cart.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-input.js' | asset_url }}" defer="defer"></script>

{%- comment -%} Inline visibility until JS loads (prevents flash) {%- endcomment -%}
<style>.volt-cart-drawer { visibility: hidden; }</style>

<cart-drawer class="volt-cart-drawer{% if cart == empty %} is-empty{% endif %}">

  {%- comment -%} Overlay {%- endcomment -%}
  <div id="CartDrawer-Overlay" class="volt-cart-drawer__overlay"></div>

  {%- comment -%} Panel {%- endcomment -%}
  <div
    id="CartDrawer"
    class="volt-cart-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-label="Shopping cart"
    tabindex="-1"
  >

    {%- comment -%} Header {%- endcomment -%}
    <div class="volt-cart-drawer__header">
      <div class="volt-cart-drawer__header-left">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <span class="volt-cart-drawer__title">
          Cart
          {%- if cart.item_count > 0 -%}
            <span class="volt-cart-drawer__count">({{ cart.item_count }})</span>
          {%- endif -%}
        </span>
      </div>
      <button
        class="volt-cart-drawer__close"
        type="button"
        onclick="this.closest('cart-drawer').close()"
        aria-label="Close cart"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M1 1l14 14M15 1L1 15"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Empty state {%- endcomment -%}
    <div class="volt-cart-drawer__empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      <p class="volt-cart-drawer__empty-title">Your cart is empty</p>
      <button
        class="volt-btn volt-btn--outline volt-btn--sm"
        type="button"
        onclick="this.closest('cart-drawer').close()"
      >
        Continue Shopping
      </button>
    </div>

    {%- comment -%} Items form {%- endcomment -%}
    <cart-drawer-items{% if cart == empty %} class="is-empty"{% endif %}>
      <form
        action="{{ routes.cart_url }}"
        id="CartDrawer-Form"
        class="volt-cart-drawer__form"
        method="post"
      >
        <div id="CartDrawer-CartItems" class="volt-cart-drawer__items js-contents">
          {%- for item in cart.items -%}
            {%- liquid
              assign has_qty_rules = false
              if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                assign has_qty_rules = true
              endif
            -%}

            <div
              class="volt-drawer-row{% if item.parent_relationship.parent != null %} volt-drawer-row--nested{% endif %}"
              id="CartDrawer-Item-{{ item.index | plus: 1 }}"
            >
              {%- comment -%} Image {%- endcomment -%}
              {%- if item.image -%}
                <a href="{{ item.url }}" class="volt-drawer-row__img-link" tabindex="-1" aria-hidden="true">
                  <img
                    src="{{ item.image | image_url: width: 160 }}"
                    alt="{{ item.image.alt | escape }}"
                    width="80"
                    height="{{ 80 | divided_by: item.image.aspect_ratio | ceil }}"
                    loading="lazy"
                    class="volt-drawer-row__img"
                  >
                </a>
              {%- else -%}
                <div class="volt-drawer-row__img-placeholder"></div>
              {%- endif -%}

              {%- comment -%} Info + controls {%- endcomment -%}
              <div class="volt-drawer-row__body">
                <div class="volt-drawer-row__top">
                  <div class="volt-drawer-row__meta">
                    <a href="{{ item.url }}" class="volt-drawer-row__name">
                      {{- item.product.title | escape -}}
                    </a>

                    {%- unless item.product.has_only_default_variant -%}
                      <p class="volt-drawer-row__variant">
                        {%- for option in item.options_with_values -%}
                          {{- option.value | escape -}}{% unless forloop.last %} · {% endunless %}
                        {%- endfor -%}
                      </p>
                    {%- endunless -%}

                    {%- for property in item.properties -%}
                      {%- assign property_first_char = property.first | slice: 0 -%}
                      {%- if property.last != blank and property_first_char != '_' -%}
                        <p class="volt-drawer-row__variant">{{ property.first }}: {{ property.last }}</p>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>

                  {%- comment -%} Line price {%- endcomment -%}
                  <div class="volt-drawer-row__price" aria-label="Line total">
                    {%- render 'loading-spinner' -%}
                    {%- if item.original_line_price != item.final_line_price -%}
                      <s class="volt-drawer-row__old-price">{{ item.original_line_price | money }}</s>
                      <span class="volt-drawer-row__final-price">{{ item.final_line_price | money }}</span>
                    {%- else -%}
                      <span class="volt-drawer-row__final-price">{{ item.original_line_price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>

                {%- comment -%} Qty + remove {%- endcomment -%}
                <div class="volt-drawer-row__bottom">
                  {%- assign can_update_quantity = item.instructions.can_update_quantity | default: true -%}
                  <quantity-input class="volt-qty-stepper volt-qty-stepper--sm">
                    <button
                      class="volt-qty-stepper__btn"
                      name="minus"
                      type="button"
                      aria-label="{{ 'products.product.quantity.decrease' | t: product: item.product.title | escape }}"
                      {% if can_update_quantity == false %}disabled{% endif %}
                    >−</button>
                    <input
                      class="volt-qty-stepper__input"
                      type="number"
                      name="updates[]"
                      id="Drawer-quantity-{{ item.index | plus: 1 }}"
                      value="{{ item.quantity }}"
                      {% # theme-check-disable %}
                      data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                      min="0"
                      data-min="{{ item.variant.quantity_rule.min }}"
                      {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
                      step="{{ item.variant.quantity_rule.increment }}"
                      {% # theme-check-enable %}
                      data-quantity-variant-id="{{ item.variant.id }}"
                      data-index="{{ item.index | plus: 1 }}"
                      aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                      {% if can_update_quantity == false %}disabled{% endif %}
                    >
                    <button
                      class="volt-qty-stepper__btn"
                      name="plus"
                      type="button"
                      aria-label="{{ 'products.product.quantity.increase' | t: product: item.product.title | escape }}"
                      {% if can_update_quantity == false %}disabled{% endif %}
                    >+</button>
                  </quantity-input>

                  {%- assign can_remove = item.instructions.can_remove | default: true -%}
                  <cart-remove-button
                    id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                    data-index="{{ item.index | plus: 1 }}"
                    {% unless can_remove %}class="hidden"{% endunless %}
                  >
                    <button
                      type="button"
                      class="volt-drawer-row__remove"
                      aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                      data-variant-id="{{ item.variant.id }}"
                    >
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                      </svg>
                    </button>
                  </cart-remove-button>

                  {%- if item.line_level_discount_allocations.size > 0 -%}
                    <span class="volt-drawer-row__discount">
                      {%- for discount in item.line_level_discount_allocations -%}
                        {{- discount.discount_application.title | escape -}}{% unless forloop.last %}, {% endunless %}
                      {%- endfor -%}
                    </span>
                  {%- endif -%}
                </div>

                {%- comment -%} Line error {%- endcomment -%}
                <div
                  id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                  class="volt-drawer-row__error"
                  role="alert"
                >
                  <small class="cart-item__error-text"></small>
                </div>
              </div>
            </div>

          {%- endfor -%}

          <p id="CartDrawer-LiveRegionText" class="sr-only" role="status"></p>
          <p id="CartDrawer-LineItemStatus" class="sr-only" aria-hidden="true" role="status">
            {{- 'accessibility.loading' | t -}}
          </p>
        </div>

        <div id="CartDrawer-CartErrors" class="volt-cart-drawer__errors" role="alert"></div>
      </form>
    </cart-drawer-items>

    {%- comment -%} Footer {%- endcomment -%}
    <div class="volt-cart-drawer__footer">

      {%- if settings.show_cart_note -%}
        <details class="volt-cart-drawer__note-details">
          <summary class="volt-cart-drawer__note-toggle">
            Add order note
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M1 3l4 4 4-4"/>
            </svg>
          </summary>
          <cart-note>
            <label class="sr-only" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
            <textarea
              id="CartDrawer-Note"
              class="volt-cart-drawer__note-input"
              name="note"
              form="CartDrawer-Form"
              rows="3"
              placeholder="Notes for your order…"
            >{{ cart.note }}</textarea>
          </cart-note>
        </details>
      {%- endif -%}

      {%- if cart.cart_level_discount_applications.size > 0 -%}
        <ul class="volt-cart-drawer__discounts" role="list">
          {%- for discount in cart.cart_level_discount_applications -%}
            <li class="volt-cart-drawer__discount">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ discount.title | escape }}
              <span class="volt-cart-drawer__discount-amount">−{{ discount.total_allocated_amount | money }}</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="volt-cart-drawer__subtotal" role="status">
        <span class="volt-cart-drawer__subtotal-label">Subtotal</span>
        <span class="volt-cart-drawer__subtotal-value">{{ cart.total_price | money_with_currency }}</span>
      </div>

      <p class="volt-cart-drawer__tax">
        {%- if cart.taxes_included -%}
          Tax included. Shipping calculated at checkout.
        {%- else -%}
          Taxes and shipping calculated at checkout.
        {%- endif -%}
      </p>

      <div class="volt-cart-drawer__ctas">
        <button
          type="submit"
          id="CartDrawer-Checkout"
          class="volt-btn volt-btn--primary volt-btn--lg volt-cart-drawer__checkout"
          name="checkout"
          form="CartDrawer-Form"
          {% if cart == empty %}disabled{% endif %}
        >
          Checkout
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>

        <a href="{{ routes.cart_url }}" class="volt-cart-drawer__view-cart">
          View full cart
        </a>
      </div>

      {%- if additional_checkout_buttons -%}
        <div class="volt-cart-drawer__dynamic-checkout additional-checkout-buttons">
          {{ content_for_additional_checkout_buttons }}
        </div>
      {%- endif -%}

    </div>

  </div>
</cart-drawer>
